<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.readora.controller.MainViewController"
            stylesheets="@style.css"
            styleClass="root-pane">

  <top>
    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="top-bar">
      <padding>
        <Insets top="15" right="20" bottom="15" left="20"/>
      </padding>

      <VBox spacing="3">
        <Label text="Readora" styleClass="app-title"/>
        <Label text="Smart Library Management System" styleClass="app-subtitle"/>
      </VBox>

      <Region HBox.hgrow="ALWAYS"/>

      <Label text="Dashboard" styleClass="section-title"/>
    </HBox>
  </top>

  <left>
    <VBox spacing="16" styleClass="sidebar">
      <padding>
        <Insets top="20" right="15" bottom="20" left="15"/>
      </padding>

      <Label text="Navigation" styleClass="nav-title"/>

      <Button text="Books" styleClass="nav-button"/>
      <Button text="Members" styleClass="nav-button"/>
      <Button text="Borrow Records" styleClass="nav-button"/>
      <Button text="Reports" styleClass="nav-button"/>
    </VBox>
  </left>

  <center>
    <VBox spacing="12" styleClass="content-area">
      <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
      </padding>

      <VBox spacing="12" styleClass="content-card">
        <padding>
          <Insets top="18" right="18" bottom="18" left="18"/>
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="content-header">
          <Label text="Library Records Overview" styleClass="content-title"/>
        </HBox>

        <TableView VBox.vgrow="ALWAYS" styleClass="custom-table">
          <columns>
            <TableColumn text="Book ID" prefWidth="120"/>
            <TableColumn text="Title" prefWidth="220"/>
            <TableColumn text="Author" prefWidth="180"/>
            <TableColumn text="Category" prefWidth="150"/>
            <TableColumn text="Status" prefWidth="120"/>
          </columns>
        </TableView>
      </VBox>
    </VBox>
  </center>

  <bottom>
    <HBox spacing="10" alignment="CENTER_RIGHT" styleClass="bottom-bar">
      <padding>
        <Insets top="12" right="20" bottom="12" left="20"/>
      </padding>

      <Button text="Add" styleClass="action-button"/>
      <Button text="Edit" styleClass="action-button"/>
      <Button text="Delete" styleClass="danger-button"/>
      <Button text="Refresh" styleClass="action-button"/>
    </HBox>
  </bottom>

</BorderPane>