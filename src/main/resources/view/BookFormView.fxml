<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>

<GridPane hgap="10" vgap="10" xmlns="http://javafx.com/javafx/21"
          xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="com.readora.controller.BookFormViewController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Book ID:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
    <TextField promptText="Enter Book ID" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

    <Label text="Title:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
    <TextField promptText="Enter Title" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

    <Label text="Author:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
    <TextField promptText="Enter Author" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

    <Label text="Category:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
    <TextField promptText="Enter Category" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

    <Button text="Save Book" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
</GridPane>