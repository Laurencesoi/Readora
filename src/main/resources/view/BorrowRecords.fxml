<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.readora.controller.BorrowRecordsController"
      stylesheets="@style.css">
    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <Label text="Transaction Records" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2e7d32;"/>

    <TableView fx:id="borrowTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="Record ID" prefWidth="80" />
            <TableColumn fx:id="colBook" text="Book Title" prefWidth="150" />
            <TableColumn fx:id="colMember" text="Member" prefWidth="120" />
            <TableColumn fx:id="colBorrow" text="Date Borrowed" prefWidth="110" />
            <TableColumn fx:id="colDue" text="Due Date" prefWidth="110" />
            <TableColumn fx:id="colReturn" text="Date Returned" prefWidth="110" />
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Update Status" onAction="#handleUpdateStatus" style="-fx-background-color: #4caf50; -fx-text-fill: white;"/>
        <Button text="Close" onAction="#handleClose" style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
    </HBox>
</VBox>